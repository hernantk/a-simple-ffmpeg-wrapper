{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A Simple FFmpeg Wrapper",
  "version": "1.0.0",
  "identifier": "com.herna.ffmpeg-wrapper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "A Simple FFmpeg Wrapper",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "hernantk",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hernantk/a-simple-ffmpeg-wrapper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBN0FDMUNGOUM0RDUzNkIKUldSclUwMmN6OEY2dWlwRDhUS3A2cVM5NFFUWTQwY0Mya216QWFrNkdXTW9nWGxXYTlLbjJ6OWcK"
    }
  }
}
